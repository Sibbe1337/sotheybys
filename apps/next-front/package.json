{
  "name": "next-front",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "bash scripts/build-wrapper.sh",
    "build:original": "next build",
    "build:strict": "next build && node scripts/assert-locales.js",
    "build:verify": "npm run build",
    "start": "next start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "data-quality": "node scripts/data-quality-report.js",
    "data-quality:blueprint": "node scripts/data-quality-report.js --mode=blueprint",
    "data-quality:full": "node scripts/data-quality-report.js --mode=full",
    "data-quality:auto-fix": "node scripts/blueprint-auto-fix.js",
    "data-quality:auto-apply": "node scripts/blueprint-auto-fix.js --apply",
    "data-quality:dry-run": "node scripts/blueprint-auto-fix.js --apply --dry-run"
  },
  "dependencies": {

    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@portabletext/react": "^3.2.4",
    "@sanity/client": "^6.29.1",
    "@sanity/image-url": "^1.2.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@vis.gl/react-google-maps": "^1.6.1",
    "clsx": "^2.1.1",

    "isomorphic-dompurify": "^2.11.0",
    "lucide-react": "^0.544.0",
    "next": "14.0.4",
    "next-intl": "^4.4.0",
    "nodemailer": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.32.6",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.10",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/ui": "^1.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "patch-package": "^8.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
